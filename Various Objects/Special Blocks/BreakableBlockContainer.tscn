[gd_scene load_steps=2 format=2]

[sub_resource type="GDScript" id=1]
script/source = "extends Node2D

func _ready():
	for b in self.get_children():
		b.connect(\"block_broken\",self,\"destroyAdjacent\")
		
func destroyAdjacent():
	for b in self.get_children():
		if b is StaticBody2D:
			if b.isAlive:
				b.killSelf()

func destroy_children(_discard=false, _discard2=false):
	destroyAdjacent()
"

[node name="BreakableBlockContainer" type="Node2D"]
script = SubResource( 1 )
__meta__ = {
"_edit_group_": true,
"_editor_description_": "When a child block is broken, all other blocks in this container will be broken at the same time.
If you want to adjust breakable block time, use BlockEnablerDisabler instead."
}
